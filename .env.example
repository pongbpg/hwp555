# =======================
# SHARED Database Config
# =======================
MONGODB_URI=mongodb://localhost:27017/test
JWT_SECRET=your-secret-key-change-in-production

# =======================
# Test Credentials
# =======================
TEST_EMAIL=test@example.com
TEST_PASSWORD=testpassword123

# =======================
# Public API (external)
# =======================
# API key สำหรับให้ระบบภายนอกอ่าน catalog สินค้า — คั่นหลาย key ด้วย comma รองรับหลาย partner
# gen ด้วย: openssl rand -hex 32   (ปล่อยว่าง = ปิด Public API ตอบ 503)
PUBLIC_API_KEYS=

